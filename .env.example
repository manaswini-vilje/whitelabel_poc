# Active brand selection
ACTIVE_BRAND=default
# BRAND_CONFIG_PATH=brands/client-template.json

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://your-openai-resource.cognitiveservices.azure.com
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# Azure Document Intelligence
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://your-doc-intelligence-resource.cognitiveservices.azure.com/
AZURE_DOCUMENT_INTELLIGENCE_KEY=your-document-intelligence-key

# Storage for brands that use the shared default env name
AZURE_STORAGE_CONNECTION_STRING=your-default-storage-connection-string

# Optional examples for brand-specific storage env names
# CLIENT_TEMPLATE_AZURE_STORAGE_CONNECTION_STRING=your-client-storage-connection-string
# ACME_AZURE_STORAGE_CONNECTION_STRING=your-acme-storage-connection-string

# Optional legacy OpenAI key if you use non-Azure OpenAI elsewhere
# OPENAI_API_KEY=your-openai-key
